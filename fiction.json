{
  "_meta": {
    "version": "2.0",
    "description": "Fictional settings mapped to WMO weather codes for Open-Meteo weather bots",
    "source_api": "Open-Meteo — field: current.weather_code",
    "wmo_reference": "https://open-meteo.com/en/docs#weathervariables",
    "fields": {
      "setting": "Name of the fictional world/location",
      "source": "Franchise or work of origin",
      "source_type": "sci-fi | fantasy | video-game | tabletop | anime | film | literature | mixed",
      "location": "Specific in-world location name",
      "flavor": "Short atmospheric description for bot message (1-2 sentences)",
      "tone": "bleak | cozy | epic | eerie | whimsical | tense | serene | oppressive",
      "temp_bias": "hot | warm | neutral | cool | cold | freezing — cross-reference with temperature_2m",
      "tags": "additional descriptors for filtering"
    },
    "wmo_groups": {
      "0": "Clear sky",
      "1": "Mainly clear",
      "2": "Partly cloudy",
      "3": "Overcast",
      "45": "Fog",
      "48": "Icy fog",
      "51": "Light drizzle",
      "53": "Moderate drizzle",
      "55": "Dense drizzle",
      "56": "Light freezing drizzle",
      "57": "Heavy freezing drizzle",
      "61": "Slight rain",
      "63": "Moderate rain",
      "65": "Heavy rain",
      "66": "Light freezing rain",
      "67": "Heavy freezing rain",
      "71": "Slight snow",
      "73": "Moderate snow",
      "75": "Heavy snow",
      "77": "Snow grains",
      "80": "Slight rain showers",
      "81": "Moderate rain showers",
      "82": "Violent rain showers",
      "85": "Slight snow showers",
      "86": "Heavy snow showers",
      "95": "Thunderstorm",
      "96": "Thunderstorm with slight hail",
      "99": "Thunderstorm with heavy hail"
    }
